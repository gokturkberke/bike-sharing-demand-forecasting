# Data — keep directory structure (via .gitkeep) but don't track the actual files
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Trained model artifacts
models/*
!models/.gitkeep

# Generated reports (regeneratable); keep metrics.json and PNG figures
reports/figures/*
reports/submissions/*
!reports/figures/.gitkeep
!reports/figures/*.png
!reports/submissions/.gitkeep
